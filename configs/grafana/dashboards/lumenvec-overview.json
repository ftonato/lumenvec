{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "expr": "rate(lumenvec_core_ann_searches_total[5m])",
          "legendFormat": "ANN searches/s",
          "refId": "A"
        },
        {
          "expr": "rate(lumenvec_core_ann_fallbacks_total[5m])",
          "legendFormat": "ANN fallbacks/s",
          "refId": "B"
        }
      ],
      "title": "ANN Search Traffic",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "rate(lumenvec_core_ann_eval_top1_matches_total[15m]) / clamp_min(rate(lumenvec_core_ann_eval_samples_total[15m]), 0.0001)",
          "legendFormat": "Top-1 match ratio",
          "refId": "A"
        },
        {
          "expr": "rate(lumenvec_core_ann_eval_overlap_results_total[15m]) / clamp_min(rate(lumenvec_core_ann_eval_compared_results_total[15m]), 0.0001)",
          "legendFormat": "Overlap ratio",
          "refId": "B"
        }
      ],
      "title": "ANN Quality Ratios",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "targets": [
        {
          "expr": "lumenvec_core_cache_bytes",
          "legendFormat": "Cache bytes",
          "refId": "A"
        },
        {
          "expr": "lumenvec_core_disk_file_bytes",
          "legendFormat": "Disk file bytes",
          "refId": "B"
        }
      ],
      "title": "Storage Footprint",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
